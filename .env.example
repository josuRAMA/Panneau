# PostgreSQL Database Configuration
# Copy this file to .env and update the values for your environment

# Database connection string using psycopg2 PostgreSQL driver
# Format: postgresql+psycopg2://username:password@host:port/database_name
PANNEAU_DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/PanneauSolaireDB

# Alternative (optional): DATABASE_URL
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/PanneauSolaireDB
